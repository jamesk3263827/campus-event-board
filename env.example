# .env.example
# ─────────────────────────────────────────────────────────────────────────────
# Template for local docker-compose environment variables.
#
# HOW TO USE:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in every value below in the new .env file.
#   3. .env is listed in .gitignore — it will never be committed.
#      This .env.example file IS committed — it documents what's needed
#      without exposing any secrets.
# ─────────────────────────────────────────────────────────────────────────────


# ── Firebase Service Account ──────────────────────────────────────────────────
# Paste the ENTIRE contents of firebase-admin-key.json as a single line.
#
# How to get a single line in VS Code:
#   1. Open firebase-admin-key.json
#   2. Press Cmd+Shift+P (Mac) or Ctrl+Shift+P (Windows)
#   3. Type "Join Lines" and press Enter
#   4. Copy the result and paste it here after the = sign
#
# This same value is used by both the Node service and the Java service.
FIREBASE_SERVICE_ACCOUNT_JSON=


# ── Internal Shared Secret ────────────────────────────────────────────────────
# A random string used to authenticate calls from the Java service to Node's
# /internal/* endpoints. Must be the same value on both services.
#
# Generate one with:   openssl rand -hex 32
INTERNAL_SECRET=


# ── Email (Gmail) ─────────────────────────────────────────────────────────────
# The Gmail address used to send notification emails.
EMAIL_USER=

# A Gmail App Password — NOT your regular Gmail password.
# How to create one:
#   1. Go to myaccount.google.com → Security → 2-Step Verification (must be on)
#   2. Scroll down to "App passwords"
#   3. Create a new app password for "Mail" on "Other device"
#   4. Copy the 16-character password and paste it here
EMAIL_PASS=
